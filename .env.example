# Örnek ortam değişkenleri — kopyalayıp .env.local olarak düzenleyin.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Giriş: kullanıcı adları eymen ve ece (lib/admin-users.ts); şifre her ikisi için aynı.
ADMIN_PASSWORD=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# wa.me için sadece rakamlar (örn. 905XXXXXXXXX). Öncelik NEXT_PUBLIC_WHATSAPP_NUMBER.
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_PHONE=

# Optional: run `npm run translate` to generate messages/de.json and messages/fr.json from en.json
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=
