# wa.me için sadece rakamlar (örn. 905XXXXXXXXX). Öncelik NEXT_PUBLIC_WHATSAPP_NUMBER.
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_PHONE=
